#!name=360 摄像机去广告
#!desc=屏蔽 360 摄像机相关广告域名，并删除 jia.360.cn 配置接口里的广告配置字段。适用于 Shadowrocket / Surge。
#!author=Akira
#!category=去广告

[Rule]
DOMAIN,ad.jia.360.cn,REJECT
DOMAIN,ad.iot.360.cn,REJECT

[Script]
360摄像机-配置去广告 = type=http-response,pattern=^https:\/\/jia\.360\.cn\/conf\/v1\.json,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/akiralereal/proxy-configs/main/scripts/360_camera_remove_ads.js

[MITM]
hostname = %APPEND% jia.360.cn, ad.jia.360.cn, ad.iot.360.cn
